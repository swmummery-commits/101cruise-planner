# Base44 Finder — local env template for ship lookup
# Copy to .env in the repo root (never commit .env).
# CRM booking uses separate variables — do not put CRM keys here.

BASE44_FINDER_APP_ID=
BASE44_FINDER_API_KEY=

# Supabase — required for Cruise Intelligence import script and Netlify functions.
# Never expose SUPABASE_SERVICE_ROLE_KEY to browser / Squarespace code.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional — Cruise Finder destination hero images (Unsplash preferred when set).
# Without this key, destination-hero falls back to Openverse (royalty-free).
# UNSPLASH_ACCESS_KEY=

# Required for Cruise Finder live sailing search (Netlify Functions only — never expose to the browser).
# Create a key at https://api-dashboard.search.brave.com/
# BRAVE_SEARCH_API_KEY=
