# Base44 Finder — local env template for ship lookup
# Copy to .env in the repo root (never commit .env).
# CRM booking uses separate variables — do not put CRM keys here.

BASE44_FINDER_APP_ID=
BASE44_FINDER_API_KEY=

# Optional — Cruise Finder destination hero images (Unsplash preferred when set).
# Without this key, destination-hero falls back to Openverse (royalty-free).
# UNSPLASH_ACCESS_KEY=
