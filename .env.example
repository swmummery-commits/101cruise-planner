# Base44 Finder — local env template for ship lookup
# Copy to .env in the repo root (never commit .env).
# CRM booking uses separate variables — do not put CRM keys here.

BASE44_FINDER_APP_ID=
BASE44_FINDER_API_KEY=

# Supabase — required for Cruise Intelligence import script and Netlify functions.
# Never expose SUPABASE_SERVICE_ROLE_KEY to browser / Squarespace code.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional — Cruise Finder destination hero images (Unsplash preferred when set).
# Without this key, destination-hero falls back to Openverse (royalty-free).
# UNSPLASH_ACCESS_KEY=

# Required for Cruise Finder live sailing search (Netlify Functions only — never expose to the browser).
# Create a key at https://api-dashboard.search.brave.com/
# BRAVE_SEARCH_API_KEY=

# Sprint 14A — Cruise Finder Engine flag (server-side only).
# Default v1 keeps the existing Discovery-catalogue customer path.
# v2 is prepared but NOT activated in Phase 1 (HOLD DEPLOY).
# CRUISE_FINDER_ENGINE=v1

# OpenAI — required for Sprint 10D Research Content generation (and Admin itinerary extract).
# Add this in Netlify Site settings → Environment variables (server-only; never expose to the browser).
# OPENAI_API_KEY=
# Optional model override (defaults to gpt-4.1-mini):
# OPENAI_RESEARCH_MODEL=gpt-4.1-mini
# OPENAI_ITINERARY_MODEL=gpt-4.1-mini

TRACK_CRUISES_RAPIDAPI_KEY=
TRACK_CRUISES_RAPIDAPI_HOST=cruise-pricing-api1.p.rapidapi.com
